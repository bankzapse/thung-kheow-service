# ============================================================
# Recycle Fund — Environment variables
# คัดลอกเป็น .env.local แล้วเติมค่า
# ⚠️ PRODUCTION ต้องตั้งค่า [REQUIRED] ให้ครบ ไม่งั้นแอปจะ fallback เป็น "โหมดเดโม" เงียบ ๆ (อันตราย)
#    ตัวที่ไม่มี [REQUIRED] = ออปชัน
# ============================================================

# ---------- Supabase (Phase 1: backend จริง) — [REQUIRED prod] ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # หรือ NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=       # server-only — ห้าม expose ฝั่ง client

# ---------- Google Maps ----------
GOOGLE_MAPS_API_KEY=               # server: Distance Matrix (จัดเส้นทางระยะถนนจริง) — ไม่มี = fallback เส้นตรง

# ---------- LINE Messaging API / OA (แจ้งเตือนผู้ขาย) ----------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
NEXT_PUBLIC_LINE_ADD_FRIEND_URL=https://line.me/R/ti/p/@your_oa_id

# ---------- LINE Login (OAuth: เชื่อมบัญชี) ----------
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_REDIRECT_URI=http://localhost:3000/api/line/callback

# ---------- LINE LIFF (ผู้ขายเปิดแอปในไลน์ + auto-login) ----------
NEXT_PUBLIC_LIFF_ID=

# ---------- SMS OK (OTP ยืนยันเบอร์โทร) — [REQUIRED prod] ----------
# ขอ key/secret + ลงทะเบียน Sender ID ที่ https://developer.smsok.co
SMSOK_API_KEY=
SMSOK_API_SECRET=
SMSOK_SENDER=Chao-Dee          # ต้องเป็น Sender ID ชนิด OTP/Transactional (ไม่ใช่ Generic/โฆษณา) ไม่งั้นโดน Anti-Spam
# SMSOK_API_URL=https://api.smsok.co   # ออปชัน
OTP_SECRET=                    # [REQUIRED prod] สุ่มสตริงยาว ๆ เซ็นโทเคน OTP (prod ต้องตั้ง ไม่งั้น verify จะปิดตาย fail-closed)
                               # สร้างด้วย: openssl rand -base64 32
                               # ไม่ตั้ง = fallback ไปใช้ SMSOK_API_SECRET (ใช้ได้แต่ไม่ควร — secret ปนหน้าที่กัน)

# ---------- SEO / เว็บ ----------
NEXT_PUBLIC_SITE_URL=              # [REQUIRED prod] โดเมนจริง เช่น https://app.thungkhiao.co
                                   # ใช้ทำ canonical / OG / sitemap / JSON-LD — ตั้งผิด = Google เก็บ URL ผิดโดเมน
                                   # ไม่ตั้ง = ใช้ https://app.thungkhiao.co (ดู src/lib/site.ts)

# ---------- อื่น ๆ ----------
NEXT_PUBLIC_COMPANY_PROMPTPAY=     # [REQUIRED prod] พร้อมเพย์บริษัท (ปลายทางเติมเครดิตพาร์ทเนอร์)
                                   # เบอร์ 10 หลัก หรือเลขบัตร ปชช. 13 หลัก · ไม่ตั้ง/ผิดรูปแบบ = ซ่อน QR เติมเครดิต (fail-closed)
                                   # ⚠️ NEXT_PUBLIC_* ฝังตอน build — แก้ค่าแล้วต้อง Redeploy
# NEXT_PUBLIC_DEMO=off             # "off" = ปิดทางลัดโหมดเดโมที่ /app (โหมด Supabase ปิดให้อัตโนมัติอยู่แล้ว)

# ---------- Push Notification (แอป native — FCM) ----------
# Firebase → Project Settings → Service accounts → Generate new private key → วางเนื้อ JSON ทั้งก้อน
FCM_SERVICE_ACCOUNT_JSON=

# Push auto-trigger (Supabase DB Webhook → /api/push/hook)
PUSH_HOOK_SECRET=
